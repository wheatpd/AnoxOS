#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <map>
#include <set>
#include <thread>
#include <chrono>
#include <algorithm>
#include <cstring>
#include <sstream>
#include <sys/stat.h>
#include <sys/types.h>
#include <dirent.h>
#include <unistd.h>
#include <signal.h>
#include <fcntl.h>

using namespace std;
typedef unsigned char byte;
typedef unsigned int uint32;

struct FolderConfig { string path; bool recursive; };
struct FileMetadata { vector<byte> mac; long long lastWrite; bool exists; };

map<string, FileMetadata> db;
map<string, bool> keysCreated;
set<string> runningProcesses;

string logDirectory = "/home/developer/secure_files/logs"; 
string currentSecret;

vector<FolderConfig> folders = { {"/", true} };
set<string> whitelist = { "systemd", "kthreadd", "syslogd", "bash", "sh", "integrity_srv", "openbox", "Xorg" };

inline uint32 rotl(uint32 x, int n) { return (x << n) | (x >> (32 - n)); }
inline uint32 G(uint32 x) { x ^= rotl(x, 13); x ^= rotl(x, 23); return x; }

void belt_block_encrypt(uint32& a, uint32& b, uint32& c, uint32& d, const uint32* k) {
    for (int i = 0; i < 8; i++) {
        b ^= G(a + k[(7 * i + 0) % 8]); c ^= G(d + k[(7 * i + 1) % 8]);
        a -= G(b + k[(7 * i + 2) % 8]); d += G(c + k[(7 * i + 3) % 8]);
        b ^= G(a + k[(7 * i + 4) % 8]); c ^= G(d + k[(7 * i + 5) % 8]);
        a -= G(b + k[(7 * i + 6) % 8]); d += G(c + k[(7 * i + 7) % 8]);
    }
}

vector<uint32> generateHardwareKey() {
    ifstream uuidFile("/sys/class/dmi/id/product_uuid");
    string uuid = "AnoxOS_Fallback_Salt_2026";
    if (uuidFile) { getline(uuidFile, uuid); uuidFile.close(); }
    vector<uint32> key(8, 0x55555555);
    for (size_t i = 0; i < uuid.length(); i++) {
        key[i % 8] = rotl(key[i % 8], 5) ^ uuid[i];
    }
    return key;
}

vector<byte> computeSecureMAC(const string& filepath, const uint32* hw_key) {
    ifstream f(filepath, ios::binary);
    if (!f) return {};
    f.seekg(0, ios::end); size_t size = f.tellg(); f.seekg(0, ios::beg);
    vector<byte> data(size); f.read((char*)data.data(), size); f.close();

    uint32 state[4] = { 0x01020304, 0x05060708, 0x090A0B0C, 0x0D0E0F10 };
    uint32 path_salt = 0;
    for (char c : filepath) path_salt = rotl(path_salt, 5) ^ c;
    state[0] ^= path_salt; state[3] ^= path_salt;

    for (size_t offset = 0; offset < data.size(); offset += 16) {
        uint32 block[4] = { 0 };
        size_t chunk = min((size_t)16, data.size() - offset);
        memcpy(block, data.data() + offset, chunk);
        for (int i = 0; i < 4; i++) state[i] ^= block[i];
        belt_block_encrypt(state[0], state[1], state[2], state[3], hw_key);
    }
    vector<byte> res(16); memcpy(res.data(), state, 16);
    return res;
}

string getIkeyPath(const string& fullPath) {
    string safePath = fullPath;
    replace(safePath.begin(), safePath.end(), '/', '_');
    return "/dev/shm/.anox_db/" + safePath + ".ikey";
}

void loadConfig() {
    ifstream cfg("/etc/anox_integrity.conf");
    if (cfg) {
        string path;
        if (getline(cfg, path) && !path.empty()) {
            logDirectory = path;
        }
        cfg.close();
    }
}

void writeLogToFile(const string& logMsg) {
    time_t now = time(nullptr);
    char timeStr[20];
    strftime(timeStr, sizeof(timeStr), "%Y-%m-%d %H:%M:%S", localtime(&now));
    
    mkdir(logDirectory.c_str(), 0700);
    string logFilePath = logDirectory + "/anox_security.log";
    
    ofstream logFile(logFilePath, ios::app);
    if (logFile) {
        logFile << "[" << timeStr << "] " << logMsg << "\n";
        logFile.close();
    }
}

string generateDynamicSecret() {
    const char charset[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
    string secret = "ANOX-";
    ifstream urandom("/dev/urandom", ios::binary);
    if (urandom) {
        for (int i = 0; i < 8; i++) {
            char c;
            urandom.read(&c, 1);
            secret += charset[static_cast<unsigned char>(c) % (sizeof(charset) - 1)];
        }
        urandom.close();
    } else {
        secret += "FALLBACK";
    }
    return secret;
}

void listenSecretTrigger() {
    string fifoPath = "/dev/shm/.sys_control";
    mkfifo(fifoPath.c_str(), 0600);
    while (true) {
        int fd = open(fifoPath.c_str(), O_RDONLY);
        if (fd >= 0) {
            char buf[128]; memset(buf, 0, sizeof(buf));
            read(fd, buf, sizeof(buf) - 1); close(fd);
            string cmd(buf);
            if (!cmd.empty() && cmd.back() == '\n') cmd.pop_back();

            if (cmd == currentSecret) {
                string backupPath = logDirectory + "/anox_security_BACKUP.log";
                string currentLog = logDirectory + "/anox_security.log";
                rename(currentLog.c_str(), backupPath.c_str());
                writeLogToFile("[SYSTEM] SECRET TRIGGER ACCEPTED. Logs rotated to BACKUP.");
            }
        }
        this_thread::sleep_for(chrono::milliseconds(500));
    }
}

void scanDirectory(string directory, bool recursive, const uint32* hw_key) {
    if (directory.empty()) return;
    if (directory.back() != '/') directory += '/';

    if (directory == "/proc/" || directory == "/sys/" || directory == "/dev/" || 
        directory == "/run/" || directory == "/tmp/" || directory == "/var/run/" ||
        directory == (logDirectory + "/")) return;

    DIR* dir = opendir(directory.c_str()); if (!dir) return;
    struct dirent* entry; struct stat fileStat;

    while ((entry = readdir(dir)) != nullptr) {
        string name = entry->d_name;
        if (name == "." || name == "..") continue;
        string fullPath = directory + name;
        if (stat(fullPath.c_str(), &fileStat) < 0) continue;

        if (S_ISDIR(fileStat.st_mode)) {
            if (recursive) scanDirectory(fullPath, true, hw_key);
        } else {
            long long currentTime = (long long)fileStat.st_mtime;
            string kp = getIkeyPath(fullPath);

            if (db.find(fullPath) == db.end()) {
                vector<byte> mac = computeSecureMAC(fullPath, hw_key);
                db[fullPath].mac = mac; db[fullPath].lastWrite = currentTime; db[fullPath].exists = true;
                
                ofstream kf(kp, ios::binary);
                if (kf) { kf.write((char*)mac.data(), 16); kf.close(); keysCreated[kp] = true; }
            } else {
                db[fullPath].exists = true;
                if (db[fullPath].lastWrite != currentTime) {
                    vector<byte> newMac = computeSecureMAC(fullPath, hw_key);
                    if (newMac != db[fullPath].mac) {
                        writeLogToFile("[ALERT-FILE_CHANGED] -> " + fullPath);
                        db[fullPath].mac = newMac;
                        ofstream kf(kp, ios::binary); if (kf) { kf.write((char*)newMac.data(), 16); kf.close(); }
                    }
                    db[fullPath].lastWrite = currentTime;
                }
            }
        }
    }
    closedir(dir);
}

void monitorActivity() {
    static bool first = true; set<string> cp;
    DIR* procDir = opendir("/proc"); if (!procDir) return;
    struct dirent* entry;
    while ((entry = readdir(procDir)) != nullptr) {
        if (entry->d_type == DT_DIR && isdigit(entry->d_name[0])) {
            ifstream cmdFile("/proc/" + string(entry->d_name) + "/comm");
            if (cmdFile) {
                string pName; getline(cmdFile, pName);
                if (!pName.empty() && whitelist.find(pName) == whitelist.end()) cp.insert(pName);
            }
        }
    }
    closedir(procDir);
    if (!first) {
        for (auto const& p : cp) if (runningProcesses.find(p) == runningProcesses.end()) writeLogToFile("[PROCESS-START] -> " + p);
        for (auto const& p : runningProcesses) if (cp.find(p) == cp.end()) writeLogToFile("[PROCESS-STOP]  -> " + p);
    }
    runningProcesses = cp; first = false;
}

int main() {
    if (fork() > 0) exit(0); setsid(); if (fork() > 0) exit(0);

    mkdir("/dev/shm/.anox_db", 0700);

    loadConfig();

    currentSecret = generateDynamicSecret();
    mkdir(logDirectory.c_str(), 0700);
    ofstream sf(logDirectory + "/session_secret.txt");
    if (sf) {
        sf << currentSecret << "\n";
        sf.close();
    }

    vector<uint32> hw_key = generateHardwareKey();

    pid_t my_pid = getpid();
    ofstream mod_file("/dev/hide_proc");
    if (mod_file) { mod_file << my_pid; mod_file.close(); }

    thread triggerThread(listenSecretTrigger);
    triggerThread.detach();

    int fileCheckCounter = 0;
    while (true) {
        monitorActivity();
        if (fileCheckCounter++ % 20 == 0) { 
            for (auto& [path, meta] : db) meta.exists = false;
            for (size_t i = 0; i < folders.size(); i++) scanDirectory(folders[i].path, folders[i].recursive, hw_key.data());
            for (auto it = db.begin(); it != db.end(); ) {
                if (!it->second.exists) {
                    string kp = getIkeyPath(it->first);
                    unlink(kp.c_str()); keysCreated.erase(kp);
                    writeLogToFile("[ALERT-FILE_DELETED] -> " + it->first);
                    it = db.erase(it);
                } else ++it;
            }
        }
        this_thread::sleep_for(chrono::milliseconds(500));
    }
    return 0;
}